<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CALCULADORA DE PERÍMETRO\nÁREA E COMBUSTÍVEL"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlign="center"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/editLarguraA"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="LARGURA A"
                android:inputType="numberDecimal" />
            <EditText
                android:id="@+id/editLarguraB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="LARGURA B"
                android:inputType="numberDecimal" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PERÍMETRO:" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ÁREA:" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textPerimetro"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00000"
                android:textSize="24sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/textArea"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00000"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCalcularArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calcular Area/Perimetro"
            android:layout_marginTop="10dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="20dp" />

        <EditText
            android:id="@+id/editTempoGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tempo Gasto (h)"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/editVelocidadeMedia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Média Velocidade (km/h)"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/editMediaConsumo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Média Combustível (km/l)"
            android:inputType="numberDecimal" />

